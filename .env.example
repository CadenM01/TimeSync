MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
MONGODB_DB=timesync
PORT=8080

# Required in production for Caddy + auto-HTTPS. The domain whose A record
# points at this server. Caddy will provision a Let's Encrypt cert for it.
TIMESYNC_DOMAIN=timesync.example.com

# 127.0.0.1 = only Caddy (local) can reach Flask; safer.
# 0.0.0.0   = expose Flask directly (use this if you haven't set up Caddy yet).
HOST=127.0.0.1

# Debug-only fallback for restrictive networks. Keep "false" normally.
MONGODB_TLS_INSECURE=false
